# Comma-separated list of active stores
STORES=target,walmart,bestbuy,gamestop,amazon,pokemoncenter,tcgplayer

# Optional filters — omit to monitor everything
# SHOW_ONLY_TYPES=etb,booster-box,bundle
# SHOW_ONLY_SETS=Prismatic Evolutions,Journey Together

# Required for Target, Best Buy, Walmart, GameStop local stock checks
ZIPCODE=62701
LOCAL_STORE_COUNT=3

# Polling intervals (ms)
PAGE_SLEEP_MIN=10000
PAGE_SLEEP_MAX=20000

# Navigation timeout (ms)
PAGE_TIMEOUT=30000

# SQLite database path
DB_PATH=./data/prices.db

# Logging level: error | warn | info | debug
LOG_LEVEL=info
